{
  "name": "gauchogrub",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev":             "next dev",
    "build":           "next build",
    "start":           "next start",
    "lint":            "next lint --max-warnings 0",
    "typecheck":       "tsc --noEmit",
    "test:unit":       "vitest run tests/unit",
    "test:e2e":        "playwright test",
    "storage:setup":   "tsx scripts/setup-storage.ts",
    "schema:apply":    "tsx scripts/apply-schema.ts",
    "seed":            "tsx scripts/seed.ts",
    "verify":          "npm run lint && npm run typecheck && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/ssr":           "^0.5.0",
    "@supabase/supabase-js":   "^2.52.0",
    "next":                    "15.1.6",
    "react":                   "19.0.0",
    "react-dom":               "19.0.0",
    "pg":                      "^8.13.1",
    "zod":                     "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test":    "^1.53.0",
    "@types/node":         "^20.17.0",
    "@types/pg":           "^8.11.0",
    "@types/react":        "^19.0.7",
    "@types/react-dom":    "^19.0.3",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer":        "^10.4.20",
    "postcss":             "^8.4.49",
    "tailwindcss":         "^3.4.17",
    "tsx":                 "^4.20.3",
    "typescript":          "^5.6.3",
    "vitest":              "^2.0.0"
  }
}
