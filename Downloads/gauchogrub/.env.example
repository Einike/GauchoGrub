# ── Supabase project ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── DB direct connection (Session Pooler, port 5432) ─────────────
SUPABASE_DB_URL=postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# ── App environment ──────────────────────────────────────────────
# Set to 'production' to disable /dev routes and enforce @ucsb.edu
APP_ENV=dev
NEXT_PUBLIC_APP_ENV=dev

# ── Public URL (for OAuth redirect) ─────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
